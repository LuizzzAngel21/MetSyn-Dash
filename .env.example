# Supabase
SUPABASE_URL=https://<tu-proyecto>.supabase.co
SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_KEY=<service-key>

# Redis
REDIS_URL=redis://localhost:6379/0

# API
API_SECRET_KEY=cambia-esto-en-produccion
ENVIRONMENT=development

# ETL — sal de anonimización (ID2 -> patient_id).
# Debe ser ESTABLE: si cambia, los patient_id cambian y se rompe el enlace
# longitudinal entre períodos. En producción usar un valor secreto y fijo.
METSYN_ANON_SALT=metsyn-gicc-usil-2026
